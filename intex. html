<!DOCTYPE html>
<head>
<meta charset="UTF-8">
CTYPE html><html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Snake Pro Ultra</title><style>
body{margin:0;font-family:sans-serif;background:#020617;color:white;text-align:center}
h1{margin-top:10px}
canvas{background:#000;margin-top:15px;border-radius:12px;box-shadow:0 0 25px #00ffcc}
.score{font-size:18px;margin-top:8px}
button{padding:10px 15px;margin:5px;border:none;border-radius:10px}
.start{background:#00ffcc;font-weight:bold}
.controls button{font-size:18px}
</style></head><body>
<h1>🐍 Snake Pro Ultra</h1>
<button class="start" onclick="startGame()">Start Game</button><div class="score" id="score">Score: 0 | 🏆 0</div>
<canvas id="c" width="300" height="300"></canvas><div class="controls">
<button onclick="dir(0,-10)">⬆️</button><br>
<button onclick="dir(-10,0)">⬅️</button>
<button onclick="dir(10,0)">➡️</button><br>
<button onclick="dir(0,10)">⬇️</button>
</div><!-- Ad Placeholder --><div style="margin-top:15px;">Ad Space</div><script>
let c=document.getElementById("c"),ctx=c.getContext("2d");
let snake,dx,dy,food,loop,score,high=localStorage.getItem("high")||0;

// sound
let eatSound=new Audio("https://actions.google.com/sounds/v1/cartoon/pop.ogg");
let gameOverSound=new Audio("https://actions.google.com/sounds/v1/cartoon/clang_and_wobble.ogg");

function startGame(){
 snake=[{x:150,y:150}];dx=10;dy=0;score=0;
 food={x:100,y:100};clearInterval(loop);
 loop=setInterval(draw,90);
}

function draw(){
 ctx.clearRect(0,0,300,300);

 // smooth glow effect
 ctx.shadowColor="#00ffcc";
 ctx.shadowBlur=10;

 snake.unshift({x:snake[0].x+dx,y:snake[0].y+dy});

 if(Math.abs(snake[0].x-food.x)<10 && Math.abs(snake[0].y-food.y)<10){
   score++;
   eatSound.play();
   food={x:Math.random()*280,y:Math.random()*280};
 } else {snake.pop();}

 ctx.fillStyle="red";
 ctx.fillRect(food.x,food.y,10,10);

 ctx.fillStyle="lime";
 snake.forEach(p=>ctx.fillRect(p.x,p.y,10,10));

 // wall collision
 if(snake[0].x<0||snake[0].y<0||snake[0].x>300||snake[0].y>300){
   clearInterval(loop);
   gameOverSound.play();
   if(score>high){high=score;localStorage.setItem("high",high)}
   alert("Game Over! Score: "+score);
 }

 document.getElementById("score").innerText="Score: "+score+" | 🏆 "+high;
}

function dir(x,y){dx=x;dy=y}
</script></body>
</html>
