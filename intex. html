<<!DOCTYPE html>
<html>
<head>
  <title>My Shop</title>
</head>
<body style="font-family:Arial">

<h2>🛒 My Shop (COD)</h2>

<div id="products"></div>

<h3>Cart</h3>
<div id="cart"></div>

<h3>Details</h3>
<input id="name" placeholder="Name"><br>
<input id="phone" placeholder="Phone"><br>
<textarea id="address" placeholder="Address"></textarea><br>

<button onclick="placeOrder()">Place COD Order</button>

<hr>

<h2>📦 Admin Panel</h2>
<div id="orders"></div>

<script>
let cart = [];

// Load products
fetch("http://localhost:5000/products")
.then(res=>res.json())
.then(data=>{
  let html="";
  data.forEach(p=>{
    html+=`<div>
      ${p.name} ₹${p.price}
      <button onclick='add(${JSON.stringify(p)})'>Add</button>
    </div>`;
  });
  document.getElementById("products").innerHTML=html;
});

function add(p){
  cart.push(p);
  document.getElementById("cart").innerText =
    cart.map(i=>i.name).join(", ");
}

function placeOrder(){
  fetch("http://localhost:5000/order",{
    method:"POST",
    headers:{"Content-Type":"application/json"},
    body:JSON.stringify({
      cart,
      customer:{
        name:document.getElementById("name").value,
        phone:document.getElementById("phone").value,
        address:document.getElementById("address").value
      }
    })
  })
  .then(res=>res.json())
  .then(d=>alert(d.msg));
}

// Admin orders
function loadOrders(){
  fetch("http://localhost:5000/admin/orders")
  .then(res=>res.json())
  .then(data=>{
    let html="";
    data.forEach(o=>{
      html+=`<div style="border:1px solid #000;margin:10px;padding:10px">
        <b>${o.customer.name}</b> (${o.customer.phone})<br>
        ${o.customer.address}<br>
        Total: ₹${o.total}<br>
        Status: ${o.status}<br>

        <select onchange="update('${o._id}', this.value)">
          <option>COD_PENDING</option>
          <option>SHIPPED</option>
          <option>DELIVERED</option>
        </select>
      </div>`;
    });
    document.getElementById("orders").innerHTML=html;
  });
}

function update(id,status){
  fetch("http://localhost:5000/admin/update/"+id,{
    method:"PUT",
    headers:{"Content-Type":"application/json"},
    body:JSON.stringify({status})
  }).then(()=>loadOrders());
}

loadOrders();
</script>

</body>
</html>